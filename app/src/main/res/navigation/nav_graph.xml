<?xml version="1.0" encoding="utf-8"?><!--
    Grafo de navegación de la app.
    - Destino inicial: LoginFragment.
    - Acción Login -> Home: al autenticarse, limpia el back stack (popUpTo login inclusive)
      para que el botón "atrás" NO regrese a la pantalla de login.
    - Acción Home -> Login: al cerrar sesión, vuelve a login limpiando todo el back stack.
    Safe Args genera a partir de estas acciones las clases LoginFragmentDirections y HomeFragmentDirections.
-->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.microsol.authfirebaseapp.ui.login.LoginFragment"
        android:label="@string/login_titulo"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.microsol.authfirebaseapp.ui.home.HomeFragment"
        android:label="@string/home_titulo"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_home_to_cursos"
            app:destination="@id/cursosFragment" />
    </fragment>

    <!--
        Feature de Cursos/Tareas: única parte de la app en capas (MVVM + Repository, ver
        domain/, data/ y presentation/). Login/Home siguen planos a propósito.
    -->
    <fragment
        android:id="@+id/cursosFragment"
        android:name="com.microsol.authfirebaseapp.presentation.cursos.CursosFragment"
        android:label="@string/cursos_titulo"
        tools:layout="@layout/fragment_cursos">

        <action
            android:id="@+id/action_cursos_to_tareas"
            app:destination="@id/tareasFragment" />

        <action
            android:id="@+id/action_cursos_to_form"
            app:destination="@id/cursoFormFragment" />
    </fragment>

    <!-- Crear/editar curso: cursoId vacío = creación, no vacío = edición (ver CursoFormFragment). -->
    <fragment
        android:id="@+id/cursoFormFragment"
        android:name="com.microsol.authfirebaseapp.presentation.cursos.form.CursoFormFragment"
        android:label="@string/curso_form_titulo_nuevo"
        tools:layout="@layout/fragment_curso_form">

        <argument
            android:name="cursoId"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="nombre"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="descripcion"
            android:defaultValue=""
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/tareasFragment"
        android:name="com.microsol.authfirebaseapp.presentation.tareas.TareasFragment"
        android:label="@string/tareas_titulo"
        tools:layout="@layout/fragment_tareas">

        <argument
            android:name="cursoId"
            app:argType="string" />

        <action
            android:id="@+id/action_tareas_to_form"
            app:destination="@id/tareaFormFragment" />
    </fragment>

    <!-- Crear/editar tarea: tareaId vacío = creación, no vacío = edición (ver TareaFormFragment). -->
    <fragment
        android:id="@+id/tareaFormFragment"
        android:name="com.microsol.authfirebaseapp.presentation.tareas.form.TareaFormFragment"
        android:label="@string/tarea_form_titulo_nuevo"
        tools:layout="@layout/fragment_tarea_form">

        <argument
            android:name="cursoId"
            app:argType="string" />
        <argument
            android:name="tareaId"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="titulo"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="fechaLimite"
            android:defaultValue="-1L"
            app:argType="long" />
    </fragment>

</navigation>
