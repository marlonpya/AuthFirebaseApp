// Reglas de seguridad de Firestore para el feature de Cursos/Tareas.
//
// "cursos" es un catálogo global compartido (no hay campo de propietario): cualquier usuario
// autenticado puede leer y escribir tanto cursos como tareas. No se despliegan automáticamente
// desde este repo: hay que copiar este archivo a la pestaña "Reglas" de Firestore en la consola
// de Firebase, o desplegarlas con `firebase deploy --only firestore:rules` si se agrega la
// Firebase CLI al proyecto más adelante.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cursos/{cursoId} {
      allow read, write: if request.auth != null;
    }
    match /tareas/{tareaId} {
      allow read, write: if request.auth != null;
    }
  }
}
